{
  "manifest_version": 3,
  "name": "Send to Blackcap Pi",
  "version": "1.0",
  "description": "Send recipe pages to Blackcap Pi.",
  "permissions": ["activeTab", "tabs", "storage"],
  "host_permissions": [
    "http://*/api/recipes/*",
    "http://*/api/recipes/add",
    "http://*/api/recipes/ping"
  ],
  "icons": {
    "16": "icon.png",
    "32": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Send to Blackcap Pi",
    "default_icon": {
      "16": "icon.png",
      "32": "icon.png"
    }
  }
}